{
  "name": "top-url-website-making",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "automate:entry": "node --env-file=.env scripts/create-and-publish-entry.mjs",
    "automate:manifest": "node --env-file=.env scripts/bootstrap-from-manifest.mjs",
    "automate:entries:periodic": "node --env-file=.env scripts/periodic-entries-from-manifest.mjs",
    "automate:entries:periodic:ci": "node scripts/periodic-entries-from-manifest.mjs",
    "automate:workflows": "node --env-file=.env scripts/seed-workflows.mjs",
    "automate:locales-branches": "node --env-file=.env scripts/seed-locales-branches.mjs",
    "automate:bulk-publish": "node --env-file=.env scripts/bulk-publish-cycle.mjs",
    "automate:delete": "node --env-file=.env scripts/delete-old-entries.mjs",
    "automate:localize": "node --env-file=.env scripts/localize-entries.mjs",
    "automate:locale-experiments": "node --env-file=.env scripts/locale-experiments.mjs",
    "automate:drive": "node --env-file=.env scripts/drive-all.mjs",
