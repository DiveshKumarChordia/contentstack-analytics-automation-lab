# =============================================================================
# Delivery API — required for npm run dev / build / Launch (see README)
# =============================================================================
VITE_CONTENTSTACK_API_KEY=
VITE_CONTENTSTACK_DELIVERY_TOKEN=
# Environment uid: Stack → Settings → Environments (e.g. production)
VITE_CONTENTSTACK_ENVIRONMENT=
# Content Delivery URL: Stack → Settings → Stack (no trailing slash), e.g. https://cdn.contentstack.io
VITE_CONTENTSTACK_DELIVERY_HOST=

# Optional — if your stack uses Branches, set the same branch as CONTENTSTACK_BRANCH (e.g. main)
# VITE_CONTENTSTACK_BRANCH=main

# -----------------------------------------------------------------------------
# Optional — omit to default the app to a single type: top_url_lines
# -----------------------------------------------------------------------------
# Comma-separated content type UIDs (match your stack / manifest)
# Demo manifest: demo_plain_text,demo_json_rte,demo_reference,demo_group,demo_blocks
VITE_CONTENTSTACK_CONTENT_TYPE_UIDS=demo_plain_text,demo_json_rte,demo_reference,demo_group,demo_blocks

# =============================================================================
# Content Management API — optional unless you run npm run automate:*
# =============================================================================
CONTENTSTACK_MANAGEMENT_TOKEN=
# Optional if VITE_CONTENTSTACK_API_KEY is set (either name works for scripts)
# CONTENTSTACK_API_KEY=

# Recommended: set for your stack (scripts use these defaults only if unset)
CONTENTSTACK_MANAGEMENT_HOST=https://api.contentstack.io
CONTENTSTACK_BRANCH=main
CONTENTSTACK_LOCALE=en-us
# Optional if VITE_CONTENTSTACK_ENVIRONMENT is already set (same publish target)
CONTENTSTACK_PUBLISH_ENVIRONMENT=

# -----------------------------------------------------------------------------
# Multi-user simulation (optional)
# -----------------------------------------------------------------------------
# Provide multiple management tokens (one per user account) as a comma-separated
# list to round-robin actions across them. Each cma-api request carries the
# token-owner's user_uid in the metering pipeline — multiple tokens → multiple
# Active Users / Entries Per Author on the dashboard. Falls back to the single
# CONTENTSTACK_MANAGEMENT_TOKEN when this is unset.
# CONTENTSTACK_MANAGEMENT_TOKENS=token_a,token_b,token_c

# Optional: only for npm run automate:entry
# CONTENTSTACK_AUTO_ENTRY_TITLE=

# Optional: custom manifest path (default scripts/content-types.manifest.json)
# CONTENTSTACK_MANIFEST_PATH=

# Optional: bootstrap without seed entry POSTs
# CONTENTSTACK_MANIFEST_SKIP_SEEDS=true

# Optional: duplicate seed title handling (set false to fail instead of skip+hydrate)
# CONTENTSTACK_MANIFEST_SKIP_DUPLICATE_SEEDS=false

# Optional: periodic batch size when manifest omits periodic.count
# CONTENTSTACK_PERIODIC_COUNT=1

# Optional: only if manifest uses taxonomy shorthand or __TAX_TERMS__ placeholders
# CONTENTSTACK_TAXONOMY_UID_CATEGORIES=
# CONTENTSTACK_TAXONOMY_TERMS_CATEGORIES=

# -----------------------------------------------------------------------------
# Workflow / locale / branch / bulk-publish seeders (optional overrides)
# -----------------------------------------------------------------------------
# Defaults live in scripts/workflows.manifest.json and scripts/locales-branches.manifest.json.
# Override the manifest paths if you maintain alternate sets:
# CONTENTSTACK_WORKFLOWS_MANIFEST_PATH=
# CONTENTSTACK_LOCALES_BRANCHES_MANIFEST_PATH=

# Bulk publish cycle: scoped to entries listed under one of these content
# types (CSV). Defaults to the UIDs in content-types.manifest.json if unset.
# CONTENTSTACK_BULK_PUBLISH_CONTENT_TYPES=demo_plain_text,demo_json_rte,demo_reference,demo_group,demo_blocks
# How many random entries to publish / unpublish per run:
# CONTENTSTACK_BULK_PUBLISH_SAMPLE=10
# CONTENTSTACK_BULK_UNPUBLISH_SAMPLE=2
# Override target locales / environments for bulk publish (CSV); defaults to
# CONTENTSTACK_LOCALE / CONTENTSTACK_PUBLISH_ENVIRONMENT respectively.
# CONTENTSTACK_BULK_PUBLISH_LOCALES=en-us,fr-fr,de-de
# CONTENTSTACK_BULK_PUBLISH_ENVIRONMENTS=production

# Delete-old-entries cycle: keeps the org under its entry cap and drives
# entry_deleted meter events. Runs first in `npm run automate:drive`.
# CONTENTSTACK_DELETE_OLDER_THAN_DAYS=7
# CONTENTSTACK_DELETE_MAX_PER_RUN=50
# CONTENTSTACK_DELETE_KEEP_NEWEST=10
# CONTENTSTACK_DELETE_CONTENT_TYPES=demo_plain_text,demo_json_rte,demo_reference,demo_group,demo_blocks

# Transition phase tuning (seed-workflows.mjs):
# Concurrency = how many entries to transit in parallel. 8 is safe on dev
# stacks; bump to 16-20 on prod-strength stacks. The same per-call throttle
# applies inside each lane.
# CONTENTSTACK_TRANSITION_CONCURRENCY=8
# CONTENTSTACK_TRANSITION_SLEEP_MS=50

# -----------------------------------------------------------------------------
# User-session auth (REQUIRED for workflow stage transitions)
# -----------------------------------------------------------------------------
# Per Contentstack docs, **management tokens cannot change workflow stages.**
# That call (POST /v3/content_types/{ct}/entries/{uid}/workflow) requires a
# user authtoken. seed-workflows.mjs's transition phase tries these paths in
# order:
#
#   Path 1 (fastest, recommended once you have it):
#     CONTENTSTACK_USER_AUTHTOKEN=<long-lived authtoken from a prior login>
#     — Skips the login flow entirely. Authtokens are usually valid for weeks.
#       Obtain by logging into the Contentstack UI and copying the
#       `authtoken` cookie value from browser DevTools (Application → Cookies),
#       OR by running a one-off interactive login.
#
#   Path 2 (recommended for 2FA-enabled accounts):
#     CONTENTSTACK_USER_EMAIL=
#     CONTENTSTACK_USER_PASSWORD=
#     CONTENTSTACK_USER_TOTP_SECRET=<base32 secret from 2FA setup>
#     — Computes the rotating 6-digit TFA code at request time using the
#       same algorithm Google Authenticator / Authy / 1Password use. No
#       extra dependencies; uses Node's built-in crypto.
#       How to obtain the TOTP secret:
#         a. Contentstack web UI → User Settings → Security → Two-Factor Auth
#         b. Disable 2FA if currently enabled
#         c. Re-enable 2FA — when the QR code appears, click "Can't scan?
#            Enter manually" / "Show key" — this reveals the base32 secret
#            (looks like JBSWY3DPEHPK3PXP, 16–32 chars, A–Z and 2–7)
#         d. Save that secret BEFORE completing setup — also feed it into
#            your authenticator app as usual so your day-to-day 2FA still works
#       Alternative: if you already have it in 1Password / Authy, those
#       apps let you reveal the setup key without resetting on Contentstack.
#
#   Path 3 (only for accounts WITHOUT 2FA enabled):
#     CONTENTSTACK_USER_EMAIL=
#     CONTENTSTACK_USER_PASSWORD=
#     — Will fail with 401 if 2FA is enabled on the account.
#
#   Path 4 (one-off interactive runs):
#     CONTENTSTACK_USER_EMAIL=
#     CONTENTSTACK_USER_PASSWORD=
#     CONTENTSTACK_USER_TFA_TOKEN=<6-digit code currently shown in authenticator>
#     — Only valid for ~30s before that code expires.
#
# CONTENTSTACK_USER_AUTHTOKEN=
# CONTENTSTACK_USER_EMAIL=
# CONTENTSTACK_USER_PASSWORD=
# CONTENTSTACK_USER_TOTP_SECRET=
# CONTENTSTACK_USER_TFA_TOKEN=
