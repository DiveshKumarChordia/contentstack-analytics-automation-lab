          "display_name": "URL Slug",
          "mandatory": true,
          "unique": true
        },
        {
          "uid": "bio",
          "field_type": "textarea",
          "data_type": "text",
          "display_name": "Biography"
        },
        {
          "uid": "avatar",
          "field_type": "file",
          "display_name": "Avatar"
        },
        {
          "uid": "email",
          "field_type": "text",
          "data_type": "email",
          "display_name": "Email"
        },
        {
          "uid": "twitter",
          "field_type": "text",
          "data_type": "text",
          "display_name": "Twitter Handle"
        },
        {
          "uid": "verified",
          "field_type": "boolean",
          "display_name": "Verified Author"
        }
      ]
    },
    {
      "uid": "category",
      "title": "Category",
      "description": "News section/category",
      "display_name_key": "name",
      "fields": [
        {
          "uid": "name",
          "field_type": "text",
          "data_type": "text",
          "display_name": "Name",
          "mandatory": true
        },
        {
          "uid": "slug",
          "field_type": "text",
          "data_type": "text",
          "display_name": "URL Slug",
          "mandatory": true,
          "unique": true
        },
        {
          "uid": "description",
          "field_type": "textarea",
          "data_type": "text",
          "display_name": "Description"
        },
        {
          "uid": "icon",
          "field_type": "text",
          "data_type": "text",
          "display_name": "Icon/Emoji"
        },
        {
          "uid": "color",
          "field_type": "text",
          "data_type": "text",
          "display_name": "Color",
          "description": "Hex color code"
        },
        {
          "uid": "site",
          "field_type": "reference",
          "content_type_uid": "site",
          "display_name": "Site"
        }
      ]
    },
    {
      "uid": "tag",
      "title": "Tag",
      "description": "Article topic tag",
      "display_name_key": "name",
      "fields": [
        {
          "uid": "name",
          "field_type": "text",
          "data_type": "text",
          "display_name": "Name",
          "mandatory": true
        },
        {
          "uid": "slug",
          "field_type": "text",
          "data_type": "text",
          "display_name": "URL Slug",
          "mandatory": true,
          "unique": true
        },
        {
          "uid": "description",
          "field_type": "textarea",
          "data_type": "text",
          "display_name": "Description"
        }
      ]
    }
  ]
}
